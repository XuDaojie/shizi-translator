{
  "productName": "Shizi",
  "version": "0.7.0-beta.5",
  "identifier": "com.shizi.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "icon": [
      "icons/icon.ico"
    ],
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "translate.html",
        "title": "Shizi 翻译",
        "width": 420,
        "height": 360,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      }
    ]
  }
}
