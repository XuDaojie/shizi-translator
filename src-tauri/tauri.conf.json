{
  "productName": "Shizi",
  "version": "0.1.0",
  "identifier": "com.shizi.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "icon": [
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "translate.html",
        "title": "Shizi - 翻译助手",
        "width": 420,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "Shizi - 设置",
        "width": 820,
        "height": 600,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "center": true,
        "visible": false
      }
    ]
  }
}
