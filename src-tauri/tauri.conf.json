{
  "productName": "Shizi",
  "version": "0.1.0",
  "identifier": "com.shizi.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "icon": [
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "settings.html",
        "title": "Shizi - 翻译助手",
        "width": 560,
        "height": 640,
        "minWidth": 480,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ]
  }
}
