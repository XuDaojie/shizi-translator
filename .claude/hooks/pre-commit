#!/bin/bash
# 提交前检查

echo "Running pre-commit checks..."

# 检查 CLAUDE.md 是否有变更，如果有则同步 AGENTS.md
if git diff --cached --name-only | grep -q "CLAUDE.md"; then
    echo "CLAUDE.md changed, syncing AGENTS.md..."
    ./scripts/sync-agents.sh
    git add AGENTS.md
fi

# 检查是否有未解决的 TODO
if grep -r "TODO" --include="*.js" --include="*.ts" --include="*.py" .; then
    echo "Warning: Found TODO comments"
fi

# 检查是否有 console.log
if grep -r "console.log" --include="*.js" --include="*.ts" .; then
    echo "Warning: Found console.log statements"
fi

echo "Pre-commit checks passed."
